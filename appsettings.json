{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Information"
    }
  },
  "LocalLLMService": {
    "BaseUrl": "http://host.docker.internal:1234",
    "AuthToken": "lmstudio",
    "Enabled": true,
    "FromModel": "Haiku",
    "ToModel": "qwen/qwen2.5-coder-14b",
    "_ToModelOptions": "Supported: 'liquid/lfm2.5-1.2b' or 'qwen/qwen2.5-coder-14b'",
    "IncludedTools": [ "Bash", "Read", "Write", "Edit", "Glob", "Grep" ],
    "AllowedMcpServers": []
  },
  "ReverseProxy": {
    "Routes": {
      "anthropic-route": {
        "ClusterId": "anthropic",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "anthropic": {
        "Destinations": {
          "primary": {
            "Address": "https://api.anthropic.com"
          }
        },
        "HttpClient": {
          "SslProtocols": [
            "Tls12",
            "Tls13"
          ],
          "EnableMultipleHttp2Connections": true
        },
        "HttpRequest": {
          "ActivityTimeout": "00:10:00"
        }
      }
    }
  }
}
