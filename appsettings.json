{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "anthropic-route": {
        "ClusterId": "anthropic",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "anthropic": {
        "Destinations": {
          "primary": {
            "Address": "https://api.anthropic.com"
          }
        },
        "HttpClient": {
          "SslProtocols": [
            "Tls12",
            "Tls13"
          ],
          "EnableMultipleHttp2Connections": true
        },
        "HttpRequest": {
          "ActivityTimeout": "00:10:00"
        }
      }
    }
  }
}
