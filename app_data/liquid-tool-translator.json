{
  "version": "1.0",
  "description": "Translates Liquid model tool calls to Claude Code tool format. Maps Liquid tool names and parameters to CC equivalents.",
  "tools": {
    "bash": {
      "target": "Bash",
      "enabled": true,
      "description": "Execute shell commands",
      "parameters": {
        "command": "command",
        "description": "description"
      }
    },
    "bash_command": {
      "target": "Bash",
      "enabled": true,
      "parameters": {
        "command": "command",
        "description": "description"
      }
    },
    "read": {
      "target": "Read",
      "enabled": true,
      "description": "Read file contents",
      "parameters": {
        "path": "file_path"
      }
    },
    "read_file": {
      "target": "Read",
      "enabled": true,
      "parameters": {
        "path": "file_path"
      }
    },
    "write": {
      "target": "Write",
      "enabled": true,
      "description": "Write file contents",
      "parameters": {
        "path": "file_path",
        "content": "content"
      }
    },
    "write_file": {
      "target": "Write",
      "enabled": true,
      "parameters": {
        "path": "file_path",
        "content": "content"
      }
    },
    "edit": {
      "target": "Edit",
      "enabled": true,
      "description": "Edit file contents",
      "parameters": {
        "path": "file_path",
        "old_string": "old_string",
        "new_string": "new_string"
      }
    },
    "glob": {
      "target": "Glob",
      "enabled": true,
      "description": "Find files by pattern",
      "parameters": {
        "pattern": "pattern"
      }
    },
    "grep": {
      "target": "Grep",
      "enabled": true,
      "description": "Search file contents",
      "parameters": {
        "pattern": "pattern"
      }
    }
  }
}
