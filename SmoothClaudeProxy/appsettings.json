{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Information"
    }
  },
  "LOG_TOKEN_FORMAT": "true",
  "LlmService": {
    "BaseUrl": "https://opencode.ai/zen/go",
    "AuthToken": "",
    "Enabled": true,
    "ApiFormat": "anthropic",
    "StripNonClaudeModels": false,
    "claude_fable_default_model": "",
    "claude_opus_default_model": "",
    "claude_sonnet_default_model": "qwen3.7-plus",
    "claude_haiku_default_model": ""
  },
  "ReverseProxy": {
    "Routes": {
      "anthropic-route": {
        "ClusterId": "anthropic",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "anthropic": {
        "Destinations": {
          "primary": {
            "Address": "https://api.anthropic.com"
          }
        },
        "HttpClient": {
          "SslProtocols": [
            "Tls12",
            "Tls13"
          ],
          "EnableMultipleHttp2Connections": true
        },
        "HttpRequest": {
          "ActivityTimeout": "00:10:00"
        }
      }
    }
  }
}
